# Core API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_VERSION=2.0.0

# File Upload Configuration
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=.py

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=structured

# CORS Configuration (configure for production)
CORS_ORIGINS=*
CORS_METHODS=GET,POST,DELETE
CORS_HEADERS=*

# Rate Limiting (requests per minute)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Analysis Configuration
ANALYSIS_TIMEOUT_SECONDS=30
MAX_COMPLEXITY_SCORE=1000

# Future: Database Configuration (uncomment when ready)
# DATABASE_URL=postgresql://user:password@localhost:5432/codeviz
# DATABASE_POOL_SIZE=10
# DATABASE_ECHO=false

# Future: Caching Configuration (uncomment when ready)
# REDIS_URL=redis://localhost:6379
# CACHE_TTL_SECONDS=3600
# CACHE_MAX_SIZE=1000

# Future: AI Integration (uncomment when ready)
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here
# OPENAI_API_KEY=sk-your-openai-key-here
# AI_MODEL=claude-3-sonnet-20240229
# AI_MAX_TOKENS=1000
# AI_TIMEOUT_SECONDS=30

# Development Settings
DEBUG_MODE=false
RELOAD_ON_CHANGE=true

# Monitoring & Observability (future)
# SENTRY_DSN=https://your-sentry-dsn
# PROMETHEUS_ENABLED=false
# HEALTH_CHECK_INTERVAL=30

# Security (production)
# SECRET_KEY=your-secret-key-for-jwt-etc
# ALLOWED_HOSTS=localhost,yourdomain.com